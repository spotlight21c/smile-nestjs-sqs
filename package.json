{
  "name": "smile-nestjs-sqs",
  "version": "0.2.1",
  "description": "NestJS module for AWS SQS built on bbc/sqs-consumer and bbc/sqs-producer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spotlight21c/smile-nestjs-sqs"
  },
  "homepage": "https://github.com/spotlight21c/smile-nestjs-sqs#readme",
  "bugs": {
    "url": "https://github.com/spotlight21c/smile-nestjs-sqs/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./terminus": {
      "types": "./dist/terminus.d.ts",
      "default": "./dist/terminus.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check . --write"
  },
  "peerDependencies": {
    "@aws-sdk/client-sqs": "^3.971.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/terminus": "^10.0.0 || ^11.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/terminus": {
      "optional": true
    }
  },
  "dependencies": {
    "sqs-consumer": "^14.2.2",
    "sqs-producer": "^8.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/testing": "^11.1.16",
    "@types/node": "^22.13.10",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "packageManager": "pnpm@9.5.0"
}
